{
  "name": "cosmo-vue-frontend",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "vite --host 127.0.0.1",
    "dev:ssr": "node ./ssr-server.mjs",
    "build": "vite build",
    "build:ssr": "vite build --ssr src/entry-server.ts --outDir dist/server",
    "build:all": "npm run build && npm run build:ssr",
    "preview": "vite preview",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@vue/server-renderer": "^3.5.13",
    "vue": "^3.5.13",
    "vue-router": "^4.4.5"
  },
  "devDependencies": {
    "typescript": "^5.7.2",
    "vite": "^6.0.1"
  }
}
