{
  "info": {
    "name": "WeatherApp — CosmoApiServer",
    "description": "API collection for the WeatherApp sample built on CosmoApiServer.\n\n**Quick start:**\n1. Import this collection and the `WeatherApp.postman_environment.json` environment.\n2. Select the **WeatherApp Local** environment.\n3. Run **Auth / Login** first — the JWT token is saved automatically to `{{token}}`.\n4. All other requests use `{{token}}` via the collection-level Authorization header.",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "auth": {
    "type": "bearer",
    "bearer": [
      {
        "key": "token",
        "value": "{{token}}",
        "type": "string"
      }
    ]
  },
  "variable": [
    {
      "key": "baseUrl",
      "value": "http://localhost:8080"
    }
  ],
  "item": [
    {
      "name": "Auth",
      "item": [
        {
          "name": "Login (admin)",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "const res = pm.response.json();",
                  "if (res.token) {",
                  "    pm.environment.set('token', res.token);",
                  "    console.log('Token saved to environment variable {{token}}');",
                  "}"
                ],
                "type": "text/javascript"
              }
            }
          ],
          "request": {
            "auth": { "type": "noauth" },
            "method": "POST",
            "header": [
              { "key": "Content-Type", "value": "application/json" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"username\": \"admin\",\n  \"password\": \"admin123\"\n}",
              "options": { "raw": { "language": "json" } }
            },
            "url": {
              "raw": "{{baseUrl}}/auth/login",
              "host": ["{{baseUrl}}"],
              "path": ["auth", "login"]
            },
            "description": "Login as **admin**. The JWT token is automatically saved to `{{token}}` and used by all other requests."
          }
        },
        {
          "name": "Login (viewer)",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "const res = pm.response.json();",
                  "if (res.token) {",
                  "    pm.environment.set('token', res.token);",
                  "    console.log('Token saved to environment variable {{token}}');",
                  "}"
                ],
                "type": "text/javascript"
              }
            }
          ],
          "request": {
            "auth": { "type": "noauth" },
            "method": "POST",
            "header": [
              { "key": "Content-Type", "value": "application/json" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"username\": \"viewer\",\n  \"password\": \"viewer123\"\n}",
              "options": { "raw": { "language": "json" } }
            },
            "url": {
              "raw": "{{baseUrl}}/auth/login",
              "host": ["{{baseUrl}}"],
              "path": ["auth", "login"]
            },
            "description": "Login as **viewer**."
          }
        },
        {
          "name": "Get Current User (me)",
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{baseUrl}}/auth/me",
              "host": ["{{baseUrl}}"],
              "path": ["auth", "me"]
            },
            "description": "Returns the authenticated user's username and role from the JWT claims. Requires a valid token."
          }
        },
        {
          "name": "Login — Invalid credentials (401)",
          "request": {
            "auth": { "type": "noauth" },
            "method": "POST",
            "header": [
              { "key": "Content-Type", "value": "application/json" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"username\": \"admin\",\n  \"password\": \"wrongpassword\"\n}",
              "options": { "raw": { "language": "json" } }
            },
            "url": {
              "raw": "{{baseUrl}}/auth/login",
              "host": ["{{baseUrl}}"],
              "path": ["auth", "login"]
            },
            "description": "Demonstrates a 401 response for invalid credentials."
          }
        }
      ]
    },
    {
      "name": "Weather",
      "item": [
        {
          "name": "Get All Forecasts",
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{baseUrl}}/weather",
              "host": ["{{baseUrl}}"],
              "path": ["weather"]
            },
            "description": "Returns all weather forecasts. Requires Bearer token."
          }
        },
        {
          "name": "Get Forecast by ID",
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{baseUrl}}/weather/1",
              "host": ["{{baseUrl}}"],
              "path": ["weather", "1"]
            },
            "description": "Returns a single forecast by ID. Change `1` to any valid ID."
          }
        },
        {
          "name": "Get Forecast by ID — Not Found (404)",
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{baseUrl}}/weather/9999",
              "host": ["{{baseUrl}}"],
              "path": ["weather", "9999"]
            },
            "description": "Demonstrates a 404 for an unknown forecast ID."
          }
        },
        {
          "name": "Create Forecast",
          "request": {
            "method": "POST",
            "header": [
              { "key": "Content-Type", "value": "application/json" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"date\": \"2026-06-01\",\n  \"temperatureC\": 28,\n  \"summary\": \"Sunny\"\n}",
              "options": { "raw": { "language": "json" } }
            },
            "url": {
              "raw": "{{baseUrl}}/weather",
              "host": ["{{baseUrl}}"],
              "path": ["weather"]
            },
            "description": "Creates a new weather forecast. Returns `201 Created` with the new resource and a `Location` header."
          }
        },
        {
          "name": "Delete Forecast",
          "request": {
            "method": "DELETE",
            "header": [],
            "url": {
              "raw": "{{baseUrl}}/weather/1",
              "host": ["{{baseUrl}}"],
              "path": ["weather", "1"]
            },
            "description": "Deletes forecast with ID 1. Returns `204 No Content` on success."
          }
        },
        {
          "name": "Get All — No Token (401)",
          "request": {
            "auth": { "type": "noauth" },
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{baseUrl}}/weather",
              "host": ["{{baseUrl}}"],
              "path": ["weather"]
            },
            "description": "Demonstrates that `/weather` returns 401 when no Bearer token is provided."
          }
        }
      ]
    },
    {
      "name": "SQL",
      "item": [
        {
          "name": "Query — sys.objects (stream rows)",
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{baseUrl}}/sql/query?sql=SELECT TOP 100 * FROM sys.objects",
              "host": ["{{baseUrl}}"],
              "path": ["sql", "query"],
              "query": [{ "key": "sql", "value": "SELECT TOP 100 * FROM sys.objects" }]
            },
            "description": "Mirrors Query.razor. Streams rows using QueryStreamAsync, returns JSON array."
          }
        },
        {
          "name": "Query — AccountTrans (stream rows)",
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{baseUrl}}/sql/query?sql=SELECT TOP 100 * FROM AccountTrans",
              "host": ["{{baseUrl}}"],
              "path": ["sql", "query"],
              "query": [{ "key": "sql", "value": "SELECT TOP 100 * FROM AccountTrans" }]
            },
            "description": "Mirrors Query.razor with the AccountTrans table."
          }
        },
        {
          "name": "JSON Stream — AccountTrans",
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{baseUrl}}/sql/json-stream?sql=SELECT TOP 200 * FROM AccountTrans",
              "host": ["{{baseUrl}}"],
              "path": ["sql", "json-stream"],
              "query": [{ "key": "sql", "value": "SELECT TOP 200 * FROM AccountTrans" }]
            },
            "description": "Mirrors JsonStream.razor. Serializes each row to a JSON object client-side."
          }
        },
        {
          "name": "FOR JSON — Products",
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{baseUrl}}/sql/for-json?sql=SELECT TOP 200 * FROM Products FOR JSON PATH",
              "host": ["{{baseUrl}}"],
              "path": ["sql", "for-json"],
              "query": [{ "key": "sql", "value": "SELECT TOP 200 * FROM Products FOR JSON PATH" }]
            },
            "description": "Mirrors JsonStreamForjson.razor. Uses QueryJsonStreamAsync — SQL must include FOR JSON PATH or AUTO."
          }
        },
        {
          "name": "SQL — No Token (401)",
          "request": {
            "auth": { "type": "noauth" },
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{baseUrl}}/sql/query?sql=SELECT TOP 10 * FROM sys.objects",
              "host": ["{{baseUrl}}"],
              "path": ["sql", "query"],
              "query": [{ "key": "sql", "value": "SELECT TOP 10 * FROM sys.objects" }]
            },
            "description": "Demonstrates 401 when no token is provided."
          }
        }
      ]
    },
    {
      "name": "Health",
      "item": [
        {
          "name": "Health Check",
          "request": {
            "auth": { "type": "noauth" },
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{baseUrl}}/health",
              "host": ["{{baseUrl}}"],
              "path": ["health"]
            },
            "description": "Public health-check endpoint. No token required."
          }
        }
      ]
    }
  ]
}
