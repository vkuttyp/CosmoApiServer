{
  "name": "liveops-sample",
  "private": true,
  "scripts": {
    "dev": "concurrently --kill-others-on-fail -n backend,frontend -c cyan,magenta \"npm run backend:dev\" \"npm run frontend:dev\"",
    "backend:dev": "dotnet run --project LiveOpsSample.csproj",
    "frontend:dev": "npm run dev --prefix frontend",
    "frontend:build": "npm run build:integrated --prefix frontend",
    "frontend:install": "npm install --prefix frontend"
  },
  "devDependencies": {
    "concurrently": "^9.0.0"
  }
}
