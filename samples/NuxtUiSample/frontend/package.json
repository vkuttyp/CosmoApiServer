{
  "name": "nuxt-ui-sample-frontend",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "nuxt dev --port 3000 --host 127.0.0.1",
    "build": "nuxt build",
    "build:integrated": "nuxt build && node -e \"const{cpSync}=require('fs');cpSync('.output/public','../wwwroot',{recursive:true})\"",
    "preview": "nuxt preview --port 3000 --host 127.0.0.1",
    "lint": "nuxt lint",
    "lint:fix": "nuxt lint --fix"
  },
  "dependencies": {
    "@nuxt/ui": "^4.0.0",
    "nuxt": "^4.0.0",
    "nuxt-auth-utils": "^0.5.0"
  },
  "devDependencies": {
    "@nuxt/eslint": "^1.0.0"
  }
}
