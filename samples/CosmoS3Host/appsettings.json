{
  "Port": 8100,
  "ValidateSignatures": false,
  "HeaderApiKey": "x-api-key",
  "AdminApiKey": "changeme-admin-key",
  "RegionString": "us-east-1",

  "Database": {
    "DatabaseType": "sqlite",
    "ConnectionString": "Data Source=./data/cosmo_s3.db"
  },

  "Storage": {
    "StorageType": "Disk",
    "DiskDirectory": "./data/objects",
    "TempDirectory": "./temp/"
  },

  "Cors": {
    "Enabled": true,
    "AllowedOrigins": [ "*" ]
  },

  "Logging": {
    "ConsoleLogging": true,
    "DiskLogging": false
  },

  "Debug": {
    "Authentication": false,
    "S3Requests": false,
    "Exceptions": false
  }
}
