@using WeatherApp.Models
@inherits RazorSlice<IEnumerable<WeatherForecast>>

<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <title>Weather Forecasts</title>
    <style>
        body { font-family: sans-serif; margin: 2rem; background: #f4f4f9; }
        table { width: 100%; border-collapse: collapse; background: white; border-radius: 8px; overflow: hidden; box-shadow: 0 4px 6px rgba(0,0,0,0.1); }
        th, td { padding: 12px 15px; text-align: left; border-bottom: 1px solid #ddd; }
        th { background-color: #007bff; color: white; }
        tr:hover { background-color: #f1f1f1; }
        .temp-warm { color: orange; font-weight: bold; }
        .temp-cold { color: blue; font-weight: bold; }
    </style>
</head>
<body>
    <h1>Weather Forecasts</h1>
    <p>Generated by <strong>CosmoApiServer Razor Slices</strong> at @DateTime.Now.ToString("HH:mm:ss")</p>

    <table>
        <thead>
            <tr>
                <th>Date</th>
                <th>Temp (C)</th>
                <th>Temp (F)</th>
                <th>Summary</th>
            </tr>
        </thead>
        <tbody>
            @foreach (var forecast in Model)
            {
                <tr>
                    <td>@forecast.Date.ToString("yyyy-MM-dd")</td>
                    <td class="@(forecast.TemperatureC > 20 ? "temp-warm" : "temp-cold")">@forecast.TemperatureC°C</td>
                    <td>@forecast.TemperatureF°F</td>
                    <td>@forecast.Summary</td>
                </tr>
            }
        </tbody>
    </table>
</body>
</html>
