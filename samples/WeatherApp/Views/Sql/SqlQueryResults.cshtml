@using WeatherApp.Models
@inherits RazorSlice<SqlQueryModel>

@if (Model.Error != null)
{
    <div class="error">
        <strong>Error:</strong> @Model.Error
    </div>
}
else
{
    <div class="card">
        <div class="meta">
            Showing @Model.Rows.Count.ToString("N0") rows — Executed in @Model.ElapsedSeconds.ToString("F3") seconds
        </div>
        
        <div style="overflow-x: auto;">
            <table>
                <thead>
                    <tr>
                        @foreach (var col in Model.Columns)
                        {
                            <th>@col</th>
                        }
                    </tr>
                </thead>
                <tbody>
                    @foreach (var row in Model.Rows)
                    {
                        <tr>
                            @foreach (var cell in row)
                            {
                                <td>@(cell ?? "NULL")</td>
                            }
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    </div>
}
